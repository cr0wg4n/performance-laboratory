{
  "name": "vue3-performance-lab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "bundle-check": "npx vite-bundle-analyzer",
    "dependency-check": "npx depcruise src",
    "dependency-snapshot": "npx depcruise src --output-type dot | dot -T svg > dependency-graph.svg"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "chart.js": "^4.5.1",
    "es-toolkit": "^1.47.1",
    "lodash": "^4.18.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/tsconfig": "^0.9.1",
    "daisyui": "^5.5.23",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.5.0",
    "eslint-plugin-oxlint": "~1.69.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "oxlint": "~1.69.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-bundle-analyzer": "^1.3.8",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
